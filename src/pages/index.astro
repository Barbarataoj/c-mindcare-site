---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="C-Mind | Empowering Clinical Care through trusted AI">
  <!-- HERO SECTION -->
  <section class="relative overflow-hidden bg-stone-900 pt-24 pb-32 lg:pt-40 lg:pb-48 text-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
      <h1 class="mx-auto max-w-4xl text-5xl font-bold tracking-tight sm:text-7xl font-display">
        Empowering clinical care  
        <span class="text-teal-400 block sm:inline">through trusted AI.</span>
      </h1>
      
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-stone-300">
        C-Mind builds evidence-based, safety-first clinical intelligence tools designed for ethical deployment within research and real-world healthcare systems.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/products" class="rounded-full bg-teal-600 px-8 py-4 text-base font-semibold text-white shadow-lg hover:bg-teal-500 hover:shadow-xl transition-all">
          View Our Products
        </a>
        <a href="/about" class="text-base font-semibold leading-6 text-stone-300 hover:text-white transition px-8 py-4">
          Our Company <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
    
    <!-- Decorative background elements -->
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,theme(colors.teal.900),theme(colors.stone.900))] opacity-80"></div>
  </section>

  <!-- BUSINESS OVERVIEW -->
  <section class="py-24 sm:py-32 bg-stone-50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">Our Philosophy</h2>
        <p class="mt-6 text-lg leading-8 text-stone-600">
          Artificial intelligence should augment—not substitute—human care. We develop specialized, highly-governed AI infrastructure that bridges the gap between structured clinical workflows and dynamic patient needs. 
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl text-center">
        <a href="/products" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-base font-medium rounded-xl text-teal-800 bg-teal-100 hover:bg-teal-200 shadow-sm transition-colors">
           Explore our Mental Health and Primary Care solutions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
